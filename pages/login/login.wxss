/* pages/login/login.wxss */
page {
  background-color: #f7f9fc;
  height: 100%;
}

.container {
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  align-items: center;
  height: 100vh;
  padding: 80rpx 40rpx;
  box-sizing: border-box;
}

/* 头部样式 */
.header {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-top: 100rpx;
}

.logo {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 40rpx;
  border-radius: 40rpx;
  box-shadow: 0 8rpx 20rpx rgba(0,0,0,0.05);
}

.title {
  font-size: 48rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 16rpx;
}

.subtitle {
  font-size: 28rpx;
  color: #888888;
}

/* 按钮区域样式 */
.login-section {
  width: 100%;
  margin-top: auto;
  margin-bottom: 60rpx;
}

.btn-primary {
  background-color: #0056A0; /* 主色调：稳重的蓝色 */
  color: #ffffff;
  font-size: 32rpx;
  font-weight: bold;
  border-radius: 50rpx;
  width: 90% !important; /* 覆盖原生组件默认宽度 */
  padding: 24rpx 0;
  margin-bottom: 30rpx;
  box-shadow: 0 10rpx 20rpx rgba(0, 86, 160, 0.2);
}

.btn-secondary {
  background-color: #ffffff;
  color: #666666;
  font-size: 30rpx;
  border-radius: 50rpx;
  width: 90% !important;
  padding: 24rpx 0;
  border: 2rpx solid #dddddd;
}

/* 底部协议样式 */
.footer {
  margin-bottom: 40rpx;
}

.agreement-label {
  display: flex;
  align-items: center;
  font-size: 24rpx;
}

.text-muted {
  color: #999999;
}

.text-link {
  color: #0056A0;
}