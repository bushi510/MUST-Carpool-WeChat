<view class="map-container">
  
  <!-- 顶部悬浮的搜索区域 -->
  <view class="search-box">
    <view class="input-row">
      <view class="dot green"></view>
      <input placeholder="你在哪里？(默认当前位置)" value="{{startName}}" disabled bindtap="chooseStart" />
    </view>
    <view class="divider"></view>
    <view class="input-row">
      <view class="dot red"></view>
      <input placeholder="你要去哪儿？" value="{{endName}}" disabled bindtap="chooseEnd" />
    </view>
  </view>

  <!-- 原生全屏地图组件 -->
  <!-- scale 设为 16 看起来像街道级别 -->
  <!-- show-location 自动显示带有方向的蓝色小圆点 -->
  <map 
    id="myMap"
    class="full-map"
    longitude="{{longitude}}" 
    latitude="{{latitude}}" 
    scale="16"
    show-location="true"
    markers="{{markers}}"
    polyline="{{polyline}}">
  </map>

  <!-- 底部操作面板 -->
  <view class="bottom-panel">
    <button class="btn-primary" bindtap="planRoute">规划路线</button>
  </view>

</view>