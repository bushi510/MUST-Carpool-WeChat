page {
  height: 100%;
}

.map-container {
  height: 100vh;
  width: 100%;
  position: relative;
  display: flex;
  flex-direction: column;
}

/* 顶部搜索框 (绝对定位悬浮在地图上) */
.search-box {
  position: absolute;
  top: 40rpx;
  left: 5%;
  width: 90%;
  background-color: #ffffff;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.1);
  z-index: 100; /* 保证悬浮在地图上方 */
  padding: 10rpx 0;
}

.input-row {
  display: flex;
  align-items: center;
  padding: 20rpx 30rpx;
}

.dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  margin-right: 20rpx;
}
.dot.green { background-color: #32CD32; }
.dot.red { background-color: #FF4500; }

.divider {
  height: 1px;
  background-color: #eeeeee;
  margin: 0 30rpx;
}

input {
  flex: 1;
  font-size: 30rpx;
  color: #333;
}

/* 地图主体区域 */
.full-map {
  flex: 1;
  width: 100%;
}

/* 底部操作面板 */
.bottom-panel {
  position: absolute;
  bottom: 0;
  width: 100%;
  background-color: #ffffff;
  padding: 40rpx 0 60rpx 0;
  border-top-left-radius: 30rpx;
  border-top-right-radius: 30rpx;
  box-shadow: 0 -4rpx 20rpx rgba(0,0,0,0.05);
  z-index: 100;
}

.btn-primary {
  background-color: #0056A0;
  color: #fff;
  width: 85% !important;
  border-radius: 50rpx;
}