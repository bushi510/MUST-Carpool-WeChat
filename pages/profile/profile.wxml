<!-- pages/profile/profile.wxml -->

<view class="profile-container">

<!-- 1. 用户信息头部：MUST 蓝背景区域 -->

<view class="user-section">
<view class="user-info">
<!-- 头像：请确保 images 文件夹下有 logo.png -->
<image class="avatar" src="../../images/logo.png" mode="aspectFill"></image>
<view class="user-detail">
<text class="nickname">M.U.S.T. 校园用户</text>
<view class="auth-tag">
<icon type="success" size="12" color="#FFD700"></icon>
<text>学生认证已通过</text>
</view>
</view>
</view>
</view>

<!-- 2. 数据简报：悬浮统计卡片 -->

<view class="stats-bar">
<view class="stats-item">
<text class="num">12</text>
<text class="label">累计拼车</text>
</view>
<view class="stats-item">
<text class="num">4.9</text>
<text class="label">信用评分</text>
</view>
<view class="stats-item">
<text class="num">85</text>
<text class="label">减少碳排(kg)</text>
</view>
</view>

<!-- 3. 功能菜单列表 -->

<view class="menu-list">
<view class="menu-item" bindtap="navigateToMyRides">
<view class="menu-left">
<text class="icon">🚗</text>
<text class="menu-text">我的发布</text>
</view>
<text class="arrow">></text>
</view>

<view class="menu-item" bindtap="navigateToJoined">
  <view class="menu-left">
    <text class="icon">🙋‍♂️</text>
    <text class="menu-text">我的参与</text>
  </view>
  <text class="arrow">></text>
</view>

<view class="menu-item" bindtap="showRealNameAuth">
  <view class="menu-left">
    <text class="icon">🆔</text>
    <text class="menu-text">实名认证</text>
  </view>
  <view class="menu-right">
    <text class="status-text">已认证</text>
    <text class="arrow">></text>
  </view>
</view>


</view>

<!-- 4. 次要功能区域 -->

<view class="menu-list mt-20">
<view class="menu-item">
<view class="menu-left">
<text class="icon">💬</text>
<text class="menu-text">反馈建议</text>
</view>
<text class="arrow">></text>
</view>
<view class="menu-item">
<view class="menu-left">
<text class="icon">⚙️</text>
<text class="menu-text">系统设置</text>
</view>
<text class="arrow">></text>
</view>
</view>

<!-- 5. 退出登录按钮 -->

<view class="logout-btn" bindtap="handleLogout">
退出登录
</view>

</view>