<!--pages/search/search.wxml-->
<view class="search-container">
  <!-- 顶部搜索框 -->
  <view class="search-header">
    <input 
      class="search-input" 
      placeholder="你要去哪儿？(如: 澳科大O座)" 
      bindinput="onInput" 
      auto-focus 
    />
  </view>

  <!-- 联想结果列表 -->
  <scroll-view scroll-y="true" class="suggestion-list">
    <view 
      class="suggestion-item" 
      wx:for="{{suggestionList}}" 
      wx:key="id" 
      bindtap="selectPlace" 
      data-item="{{item}}">
      <view class="place-title">{{item.title}}</view>
      <view class="place-address">{{item.address}}</view>
    </view>
  </scroll-view>
</view>